{
  "name": "label-compliance-checker",
  "version": "1.0.0",
  "description": "Real-Time Label Compliance Checker with Web-Scouting Intelligence Engine",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "npm run dev --prefix client",
    "install:all": "npm install && npm install --prefix client"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "groq-sdk": "^1.1.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
